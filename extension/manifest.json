{
    "manifest_version": 3,
    "name": "__MSG_appName__",
    "short_name": "__MSG_appShortName__",
    "description": "__MSG_appDescription__",
    "default_locale": "en",
    "version": "1.7.1",
    "minimum_chrome_version": "140",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": "icons/not-recording.png",
        "default_title": "__MSG_actionDefaultTitle__"
    },
    "background": {
        "service_worker": "dist/service_worker.js",
        "type": "module"
    },
    "permissions": [
        "tabCapture",
        "offscreen",
        "storage",
        "unlimitedStorage",
        "contextMenus"
    ],
    "options_page": "option.html",
    "content_security_policy": {
        "extension_pages": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'unsafe-inline'; connect-src https://*.sentry.io/ 'self';",
        "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self';"
    },
    "commands": {
        "start-recording": {
            "description": "__MSG_commandStartRecording__"
        },
        "stop-recording": {
            "description": "__MSG_commandStopRecording__"
        },
        "toggle-recording": {
            "description": "__MSG_commandToggleRecording__"
        },
        "toggle-pause-recording": {
            "description": "__MSG_commandTogglePauseRecording__"
        },
        "open-option-page": {
            "description": "__MSG_commandOpenOptionPage__"
        }
    }
}
