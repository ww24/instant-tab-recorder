{
  "name": "instant-tab-recorder",
  "version": "1.7.1",
  "type": "module",
  "description": "Google Chrome Extensions Screen Recorder",
  "scripts": {
    "build": "SOURCEMAP=1 vite build",
    "build:prod": "rm -f extension.zip && ENV_NAME=production vite build && zip -r extension.zip extension",
    "watch": "vite build --watch --mode development",
    "lint": "oxlint docs scripts src tests *.ts",
    "lint:fix": "npm run lint -- --fix",
    "fmt": "oxfmt docs scripts src tests *.ts",
    "fmt:check": "npm run fmt -- --check",
    "test": "vitest run --project node",
    "test:browser": "vitest run --project browser*",
    "test:all": "vitest run",
    "test:coverage": "npm run test:all -- --coverage",
    "site": "vite dev --config docs/vite.config.ts",
    "site:build": "vite build --config docs/vite.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ww24/instant-tab-recorder.git"
  },
  "homepage": "https://recorder.appcloud.info/",
  "author": "ww24",
  "license": "MIT",
  "dependencies": {
    "@material/web": "^2.4.1",
    "@mediabunny/flac-encoder": "1.44.1",
    "@sentry/browser": "^10.53.1",
    "lit": "^3.3.3",
    "mediabunny": "1.44.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@googleapis/chromewebstore": "^2.0.2",
    "@types/chrome": "^0.1.42",
    "@types/dom-mediacapture-transform": "^0.1.11",
    "@types/node": "^25.9.1",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.2",
    "google-auth-library": "^10.6.2",
    "marked": "^18.0.4",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.65.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.5",
    "vitest-browser-lit": "^1.0.1"
  },
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  }
}
